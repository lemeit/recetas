    <a href="/recetas" style="padding: 14px 22px; background: #2A7A6E; color: white; border-radius: 6px; text-decoration: none; font-weight: bold;">📖 Ver recetas</a>
    <a href="/guia" style="padding: 14px 22px; background: #eee; color: #333; border-radius: 6px; text-decoration: none; font-weight: bold;">📋 Pautas y sugerencias</a>
  </div>
</Layout>

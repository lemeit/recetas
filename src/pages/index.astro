---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout title="Plan Nutricional">
  <div style="display: flex; align-items: center; gap: 14px;">
    <img src={`${base}/marca.svg`} alt="Lemeit" width="56" height="56" />
    <h1 style="color: #2A7A6E; margin: 0;">Mi Plan Nutricional</h1>
  </div>
  <p style="color: #555;">Recetas del plan, con checklist de ingredientes que se guarda solo, y guía de pautas y sugerencias.</p>

  <div style="display: flex; gap: 12px; margin-top: 24px; flex-wrap: wrap;">
    <a href={`${base}/recetas`} style="padding: 14px 22px; background: #2A7A6E; color: white; border-radius: 6px; text-decoration: none; font-weight: bold;">📖 Ver recetas</a>
    <a href={`${base}/plan-semanal`} style="padding: 14px 22px; background: #2A7A6E; color: white; border-radius: 6px; text-decoration: none; font-weight: bold;">🗓️ Plan semanal</a>
    <a href={`${base}/guia`} style="padding: 14px 22px; background: #eee; color: #333; border-radius: 6px; text-decoration: none; font-weight: bold;">📋 Pautas y sugerencias</a>
  </div>
</Layout>

---
import Layout from '../../layouts/Layout.astro';
import { recetas } from '../../data/recetas.js';
import { recetasToLatexDoc, toDataUri } from '../../utils/latex.js';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const principales = recetas.filter((r) => r.categoria === 'principal');
const postres = recetas.filter((r) => r.categoria === 'postre-desayuno');

const texTodoHref = toDataUri(recetasToLatexDoc(recetas));
const texPrincipalesHref = toDataUri(recetasToLatexDoc(principales, 'ALMUERZOS Y CENAS'));
const texPostresHref = toDataUri(recetasToLatexDoc(postres, 'POSTRES Y DESAYUNOS'));

const cardStyle = "text-decoration: none; color: #333; display: block; padding: 12px 14px; background: #f9f9f9; border-radius: 6px; transition: background 0.15s;";
const btnStyle = "padding: 10px 14px; background: #f0f7f5; color: #2A7A6E; border: 1px solid #2A7A6E; border-radius: 5px; cursor: pointer; text-decoration: none; font-size: 0.9em;";
---

<Layout title="Recetas">
  <a href={`${base}/`} style="text-decoration: none; color: #2A7A6E; font-weight: bold;">← Inicio</a>
  <h1 style="color: #2A7A6E;">Recetas</h1>

  <div style="display: flex; gap: 10px; margin: 16px 0 24px; flex-wrap: wrap;" class="no-print">
    <a href={texTodoHref} download="recetas-todas.tex" style={btnStyle}>📄 Descargar TODO (.tex)</a>
    <a href={texPrincipalesHref} download="recetas-almuerzos-cenas.tex" style={btnStyle}>📄 Solo almuerzos/cenas (.tex)</a>
    <a href={texPostresHref} download="recetas-postres-desayunos.tex" style={btnStyle}>📄 Solo postres/desayunos (.tex)</a>
  </div>

  <h2>Almuerzos y cenas</h2>
  <ul style="list-style: none; padding: 0; display: grid; gap: 8px; margin-bottom: 30px;">
    {principales.map((r) => (
      <li>
        <a href={`${base}/recetas/${r.slug}`} style={cardStyle}>{r.titulo}</a>
      </li>
    ))}
  </ul>

  <h2>Postres y desayunos</h2>
  <ul style="list-style: none; padding: 0; display: grid; gap: 8px;">
    {postres.map((r) => (
      <li>
        <a href={`${base}/recetas/${r.slug}`} style={cardStyle}>{r.titulo}</a>
      </li>
    ))}
  </ul>
</Layout>

---
import Layout from '../layouts/Layout.astro';
import { semanas } from '../data/plan-semanal.js';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const cajaStyle = "background: #f9f9f9; border-radius: 6px; padding: 4px 4px 12px; margin-bottom: 24px; overflow-x: auto;";
const thStyle = "text-align: left; padding: 8px 10px; background: #2A7A6E; color: white; font-size: 0.9em;";
const tdDiaStyle = "padding: 8px 10px; font-weight: bold; color: #2A7A6E; white-space: nowrap; vertical-align: top;";
const tdStyle = "padding: 8px 10px; border-bottom: 1px solid #eee; vertical-align: top;";
---

<Layout title="Plan Semanal">
  <a href={`${base}/`} style="text-decoration: none; color: #2A7A6E; font-weight: bold;">← Inicio</a>
  <h1 style="color: #2A7A6E;">Plan Semanal</h1>
  <p style="color: #666;">Plan de almuerzos y cenas aportado por una profesional de nutrición, organizado en 4 semanas.</p>

  <div style="display: flex; gap: 10px; margin: 16px 0 24px; flex-wrap: wrap;" class="no-print">
    <button onclick="window.print()" style="padding: 10px 15px; background: #2A7A6E; color: white; border: none; border-radius: 5px; cursor: pointer;">🖨️ Imprimir</button>
  </div>

  {semanas.map((semana) => (
    <div>
      <h2>Semana {semana.numero}</h2>
      <div style={cajaStyle}>
        <table style="width: 100%; border-collapse: collapse; font-size: 0.95em;">
          <thead>
            <tr>
              <th style={thStyle}>Día</th>
              <th style={thStyle}>Almuerzo</th>
              <th style={thStyle}>Cena</th>
            </tr>
          </thead>
          <tbody>
            {semana.dias.map((d) => (
              <tr>
                <td style={tdDiaStyle}>{d.dia}</td>
                <td style={tdStyle}>{d.almuerzo}</td>
                <td style={tdStyle}>{d.cena}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  ))}
</Layout>

<style>
  @media print {
    table {
      break-inside: avoid;
    }
    h2 {
      break-after: avoid;
    }
  }
</style>

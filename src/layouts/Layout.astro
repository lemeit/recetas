---
interface Props {
  title: string;
}

const { title } = Astro.props;
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Recetas y plan nutricional" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body>
    <main style="font-family: system-ui, sans-serif; max-width: 800px; margin: 0 auto; padding: 20px; color: #333;">
      <slot />
    </main>

    <style>
      /* ESTILOS PARA IMPRIMIR: Oculta lo que no querés en el PDF */
      @media print {
        .no-print { display: none !important; }
        body { background: white !important; }
        main { padding: 0 !important; }
      }
    </style>
  </body>
</html>
